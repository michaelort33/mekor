{
  "name": "mekor",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node node_modules/next/dist/bin/next dev",
    "build": "node node_modules/next/dist/bin/next build",
    "build:vercel": "npx --yes vercel@48.4.1 build --yes",
    "start": "node node_modules/next/dist/bin/next start",
    "lint": "node node_modules/eslint/bin/eslint.js",
    "test": "node node_modules/tsx/dist/cli.mjs --test tests/**/*.test.ts",
    "prepush:deploy-check": "bash scripts/prepush-deploy-check.sh",
    "mirror:discover": "node node_modules/tsx/dist/cli.mjs scripts/mirror/01_discover.ts",
    "mirror:snapshot": "node node_modules/tsx/dist/cli.mjs scripts/mirror/02_snapshot_pages.ts",
    "mirror:extract-assets": "node node_modules/tsx/dist/cli.mjs scripts/mirror/03_extract_assets.ts",
    "mirror:build-content": "node node_modules/tsx/dist/cli.mjs scripts/mirror/04_build_content.ts",
    "mirror:build-search": "node node_modules/tsx/dist/cli.mjs scripts/mirror/05_build_search_index.ts",
    "mirror:verify": "node node_modules/tsx/dist/cli.mjs scripts/mirror/06_verify_contract.ts",
    "native:verify": "node node_modules/tsx/dist/cli.mjs scripts/mirror/08_verify_native_contracts.ts",
    "mirror:blob-sync": "node node_modules/tsx/dist/cli.mjs scripts/mirror/07_sync_blob_assets.ts",
    "mirror:render-mode-report": "node node_modules/tsx/dist/cli.mjs scripts/mirror/08_render_mode_report.ts",
    "mirror:rollout-audit": "node node_modules/tsx/dist/cli.mjs scripts/mirror/08_rollout_audit.ts",
    "template:parity-report": "node node_modules/tsx/dist/cli.mjs scripts/template/generate_parity_report.ts",
    "mirror:all": "npm run mirror:discover && npm run mirror:snapshot && npm run mirror:extract-assets && npm run mirror:build-content && npm run mirror:build-search && npm run mirror:verify",
    "visual:baseline:capture": "node node_modules/tsx/dist/cli.mjs scripts/visual-parity/capture.ts baseline",
    "visual:candidate:capture": "node node_modules/tsx/dist/cli.mjs scripts/visual-parity/capture.ts candidate",
    "visual:parity:report": "node node_modules/tsx/dist/cli.mjs scripts/visual-parity/report.ts",
    "visual:baseline:approve": "node node_modules/tsx/dist/cli.mjs scripts/visual-parity/approve-baseline.ts",
    "visual:parity:gate": "npm run visual:candidate:capture && npm run visual:parity:report",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "content:generate": "node node_modules/tsx/dist/cli.mjs scripts/content/generate-native-content.ts",
    "db:backfill:events": "node node_modules/tsx/dist/cli.mjs scripts/db/backfill-events.ts",
    "db:backfill:in-the-news": "node node_modules/tsx/dist/cli.mjs scripts/db/backfill-in-the-news.ts"
  },
  "dependencies": {
